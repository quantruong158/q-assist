{
  "appId": "com.qtech.qassist",
  "productName": "Qassist",
  "directories": {
    "output": "dist/desktop"
  },
  "files": ["dist/apps/desktop-app/browser/**/*", "dist/apps/desktop-app/electron/**/*"],
  "extraMetadata": {
    "main": "dist/apps/desktop-app/electron/main.js"
  },
  "win": {
    "target": "nsis",
    "icon": "public/favicon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "public/favicon.ico",
    "uninstallerIcon": "public/favicon.ico"
  }
}
