{
  "name": "qos",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "nx serve web-app",
    "build": "nx build web-app",
    "watch": "nx build web-app --watch --configuration development",
    "test": "nx test web-app",
    "lint": "nx lint web-app",
    "build:mobile": "nx build web-app --configuration=mobile",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "mobile:android": "pnpm run build:mobile && npx cap sync android && npx cap open android",
    "mobile:ios": "pnpm run build:mobile && npx cap sync ios && npx cap open ios",
    "firebase:emu:start": "firebase emulators:start --import .firebase/emu-data --export-on-exit .firebase/emu-data"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
