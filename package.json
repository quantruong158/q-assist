{
  "name": "q-assist",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:q-assist": "node dist/q-assist/server/server.mjs",
    "lint": "ng lint",
    "build:mobile": "ng build --configuration=mobile",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "mobile:android": "pnpm run build:mobile && npx cap sync android && npx cap open android",
    "mobile:ios": "pnpm run build:mobile && npx cap sync ios && npx cap open ios"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "~21.1.1",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/fire": "^21.0.0-rc.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-server": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@capacitor-firebase/authentication": "^8.0.1",
    "@capacitor/android": "^8.0.1",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/cli": "^8.0.1",
    "@capacitor/core": "^8.0.1",
    "@capacitor/ios": "^8.0.1",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@ng-icons/core": "^33.0.0",
    "@ng-icons/huge-icons": "^33.0.0",
    "@ng-icons/lucide": ">=32.0.0 <34.0.0",
    "@spartan-ng/brain": "0.0.1-alpha.644",
    "class-variance-authority": "^0.7.0",
    "clipboard": "^2.0.11",
    "clsx": "^2.1.1",
    "embla-carousel-angular": "^20.0.0",
    "firebase": "^12.8.0",
    "katex": "^0.16.33",
    "ngx-markdown": "^21.1.0",
    "ngx-sonner": ">=3.0.0",
    "prismjs": "^1.30.0",
    "remend": "^1.2.1",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.3.1",
    "tslib": "^2.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.0",
    "@spartan-ng/cli": "0.0.1-alpha.644",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.17.19",
    "angular-eslint": "21.1.0",
    "eslint": "^9.39.1",
    "jsdom": "^27.1.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.47.0",
    "vitest": "^4.0.8"
  }
}
